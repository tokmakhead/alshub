{
  "name": "alshub",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "start": "npm run start -w apps/web",
    "lint": "npm run lint -w apps/web",
    "db:generate": "npm run generate -w packages/database",
    "db:push": "npm run push -w packages/database",
    "db:seed": "npm run seed -w packages/database"
  }
}
