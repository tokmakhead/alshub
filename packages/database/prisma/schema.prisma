generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  ADMIN
  EDITOR
}

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum RefType {
  DRUG
  TRIAL
  PUBLICATION
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  roles     UserRole[]
  approvedContents EditorialContent[] @relation("ApprovedBy")
  auditLogs      AuditLog[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id    Int        @id @default(autoincrement())
  name  RoleName   @unique
  users UserRole[]
}

model UserRole {
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId Int

  @@id([userId, roleId])
}

model Source {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  base_url      String?
  records       SourceRecord[]
  syncJobs      SyncJob[]
}

model SourceRecord {
  id           Int      @id @default(autoincrement())
  source       Source   @relation(fields: [sourceId], references: [id])
  sourceId     Int
  externalId   String   // NCT ID, PMID, ApplNo etc.
  rawData      Json
  fetchDate    DateTime @default(now())
  editorialContents EditorialContent[]

  @@unique([sourceId, externalId])
  @@index([externalId])
}

model Drug {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  company String?
  status  String?  // FDA Approved, Phase X etc.
  @@index([name])
}

model Trial {
  id        Int      @id @default(autoincrement())
  nctId     String   @unique
  title     String
  phase     String?
  status    String?
  startDate DateTime?
  @@index([nctId])
}

model Publication {
  id        Int      @id @default(autoincrement())
  pmid      String   @unique
  title     String
  authors   String?  @db.Text
  journal   String?
  pubDate   DateTime?
  abstract  String?  @db.Text
  @@index([pmid])
}

model EditorialContent {
  id             Int             @id @default(autoincrement())
  slug           String          @unique
  title          String
  summary        String?         @db.Text
  content        String?         @db.Text
  status         ContentStatus   @default(DRAFT)
  refType        RefType
  refId          Int             // ID in Drug, Trial, or Publication
  
  sourceRecord   SourceRecord?   @relation(fields: [sourceRecordId], references: [id])
  sourceRecordId Int?
  
  aiJob          AIJob?          @relation(fields: [aiJobId], references: [id])
  aiJobId        Int?
  
  versions       EditorialVersion[]
  
  approvedBy     User?           @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedById   Int?
  approvedAt     DateTime?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status])
  @@index([refType, refId])
}

model EditorialVersion {
  id                 Int              @id @default(autoincrement())
  editorialContent   EditorialContent @relation(fields: [editorialContentId], references: [id], onDelete: Cascade)
  editorialContentId Int
  title              String
  summary            String?          @db.Text
  content            String?          @db.Text
  createdAt          DateTime         @default(now())
}

model AIJob {
  id          Int       @id @default(autoincrement())
  provider    String
  model       String
  prompt      String    @db.Text
  response    String?   @db.Text
  status      JobStatus @default(PENDING)
  editorialContents EditorialContent[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SyncJob {
  id        Int       @id @default(autoincrement())
  source    Source    @relation(fields: [sourceId], references: [id])
  sourceId  Int
  status    JobStatus @default(PENDING)
  runDate   DateTime  @default(now())
  message   String?   @db.Text
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  user      User?    @relation(fields: [userId], references: [id])
  userId    Int?
  action    String
  details   Json?
  createdAt DateTime @default(now())
}
