# Core App
APP_ENV="development" # development, staging, production
NEXT_PUBLIC_APP_NAME="ALS Hub"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
LOG_LEVEL="info" # debug, info, warn, error

# Database
DATABASE_URL="mysql://user:password@localhost:3306/alshub"

# Security
CRON_SECRET="at-least-16-characters-long"
SESSION_SECRET="at-least-32-characters-long-unique-secret"

# AI Providers
GEMINI_API_KEY="your-gemini-api-key"
AI_DEFAULT_PROVIDER="gemini"

# Data Sources (APIs)
CLINICALTRIALS_BASE_URL="https://clinicaltrials.gov/api/v2"
PUBMED_BASE_URL="https://eutils.ncbi.nlm.nih.gov/entrez/eutils"
OPENFDA_BASE_URL="https://api.fda.gov"
DAILYMED_BASE_URL="https://dailymed.nlm.nih.gov/dailymed/services/v2"
DRUGSFDA_BASE_URL=""
ORANGEBOOK_SOURCE_PATH=""
